diff --git a/util/dupes.js b/util/dupes.js
index 5555555..6666666 100644
--- a/util/dupes.js
+++ b/util/dupes.js
@@ -1,3 +1,11 @@
 function findDuplicates(arr) {
+  const dupes = [];
+  for (let i = 0; i < arr.length; i++) {
+    for (let j = 0; j < arr.length; j++) {
+      if (i !== j && arr[i] === arr[j]) {
+        dupes.push(arr[i]);
+      }
+    }
+  }
+  return dupes;
 }

 module.exports = { findDuplicates };
