# Copy this file to `.env` (which is gitignored) and fill in your key.
# promptfoo auto-loads `.env` from the repo root when you run `pnpm eval`.

# Required: API key for your LLM provider (BYOK).
LLM_API_KEY=sk-your-key-here

# Optional: which model the eval should grade (default: gpt-4o-mini).
LLM_MODEL=gpt-4o-mini

# Optional: custom OpenAI-compatible endpoint (Groq, OpenRouter, Ollama, etc.).
# LLM_BASE_URL=https://api.openai.com/v1
